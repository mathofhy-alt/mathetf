``` python
def solve_v1(k):
    sols = set()
    for n in range(1, 100):
        if (n-3)**2 == 13 - k or (n-3)**2 == 5 - k:
            sols.add(n)
    return len(sols)

for k in range(-20, 20):
    if solve_v1(k) == 3:
        print(f"k={k}")

