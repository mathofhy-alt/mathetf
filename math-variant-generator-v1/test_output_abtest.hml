56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>alpha bar{alpha}</SCRIPT></EQUATION><CHAR>의 값은 다음과 같다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000013" Lock="false" NumberingType="Equation" ZOrder="1013"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="38850" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>alpha bar{alpha} = (4+3i)(4-3i) = 4^2 - (3i)^2 = 16 - 9i^2 = 16+9 = 25</SCRIPT></EQUATION><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>분자 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000014" Lock="false" NumberingType="Equation" ZOrder="1014"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="17400" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>5(bar{alpha} bar{beta} + alpha beta)</SCRIPT></EQUATION><CHAR>의 값을 구하기 위해 먼저 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000015" Lock="false" NumberingType="Equation" ZOrder="1015"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="5400" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>alpha beta</SCRIPT></EQUATION><CHAR>를 계산한다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000016" Lock="false" NumberingType="Equation" ZOrder="1016"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="39650" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>alpha beta = (4+3i)(2+i) = 8 + 4i + 6i + 3i^2 = 8 + 10i - 3 = 5+10i</SCRIPT></EQUATION><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000017" Lock="false" NumberingType="Equation" ZOrder="1017"><SIZE Height="2600" HeightRelTo="Absolute" Protect="false" Width="20187" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>bar{alpha} bar{beta} = overline{alpha beta} = 5-10i</SCRIPT></EQUATION><CHAR>이므로</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000018" Lock="false" NumberingType="Equation" ZOrder="1018"><SIZE Height="1125" HeightRelTo="Absolute" Protect="fals