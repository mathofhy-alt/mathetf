``` python
def test_variation3():
    import math
    for a in [5, -3]:
        val = a**2 - 2*a - 7
        b = val**(1/3) if val >= 0 else -(-val)**(1/3)
        b = round(b)
        left = math.sqrt(abs(b)) * math.sqrt(val)
        print(f"a={a}, val={val}, b={b}, left={left}")

test_variation3()

