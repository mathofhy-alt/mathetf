``` python
def solve_v3():
    ans = 0
    valid_n = []
    for n in range(1, 21):
        for k in range(1, 20):
            if 2**(k+2) < n**2 <= 9 * 2**(k-1):
                ans += n
                valid_n.append(n)
                break
    return ans, valid_n

print("V3 ans:", solve_v3())

```
