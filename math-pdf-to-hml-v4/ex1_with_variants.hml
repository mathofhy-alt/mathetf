GIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>LEFT ( {1-i} over {1+ sqrt {3}i} RIGHT ) ^{13} = x+yi</SCRIPT></EQUATION><CHAR>가 성립할 때,</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000016" Lock="false" NumberingType="Equation" ZOrder="1016"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="2200" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x+y</SCRIPT></EQUATION><CHAR>의 값은? (단, </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000017" Lock="false" NumberingType="Equation" ZOrder="1017"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="3750" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>i= sqrt {-1}</SCRIPT></EQUATION><CHAR>)</CHAR></TEXT></P>
