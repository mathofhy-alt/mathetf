 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000002" Lock="false" NumberingType="Equation" ZOrder="1002"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="6100" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>beta = 2+i</SCRIPT></EQUATION><CHAR>에 대하여 켤레복소수는 각각 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000003" Lock="false" NumberingType="Equation" ZOrder="1003"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="8850" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>bar{alpha} = 4-3i</SCRIPT></EQUATION><CHAR>, </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000004" Lock="false" NumberingType="Equation" ZOrder="1004"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="7650" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>bar{beta} = 2-i</SCRIPT></EQUATION><CHAR>이다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>구하고자 하는 식 </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000005" Lock="false" NumberingType="Equation" ZOrder="1005"><SIZE Height="2600" HeightRelTo="Absolute" Protect="false" Width="32130" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>alpha bar{beta} + bar{alpha} beta + {5 bar{beta}} over {alpha} + {5 beta} over {bar{alpha}}</SCRIPT></EQUATION><CHAR>의 값을 구하기 위해 식을 두 부분으로 나누어 계산한다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>1. </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000006" Lock="false" NumberingType="Equation" ZOrder="1006"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="15900" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>alpha bar{beta} + bar{alpha} beta</SCRIPT></EQUATION><CHAR>의 값을 계산한다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000007" Lock="false" NumberingType="Equation" ZOrder="1007"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="43100" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>alpha bar{beta} = (4+3i)(2-i) = 8 - 4i + 6i - 3i^2 = 8 + 2i - 3(-1) = 11+2i</SCRIPT></EQUATION><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000008" Lock="false" NumberingType="Equation" ZOrder="1008"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="43100" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>bar{alpha} beta = (4-3i)(2+i) = 8 + 4i - 6i - 3i^2 = 8 - 2i - 3(-1) = 11-2i</SCRIPT></EQUATION><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>따라서 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000009" Lock="false" NumberingType="Equation" ZOrder="1009"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="31200" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>alpha bar{beta} + bar{alpha} beta = (11+2i) + (11-2i) = 22</SCRIPT></EQUATION><CHAR>이다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>2. </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="