orAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>2x - 5 = alpha</SCRIPT></EQUATION><CHAR>또는 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000093" Lock="false" NumberingType="Equation" ZOrder="1093"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="4400" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>2x - 5 = beta</SCRIPT></EQUATION><CHAR>입니다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>3. 위 식을 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000094" Lock="false" NumberingType="Equation" ZOrder="1094"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="600" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x</SCRIPT></EQUATION><CHAR>에 대하여 정리하면 다음과 같은 두 실근을 얻을 수 있습니다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>   </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000095" Lock="false" NumberingType="Equation" ZOrder="1095"><SIZE Height="2600" HeightRelTo="Absolute" Protect="false" Width="4420" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x = { alpha + 5} over {2}</SCRIPT></EQUATION><CHAR>또는 </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000096" Lock="false" NumberingType="Equation" ZOrder="1096"><SIZE Height="2600" HeightRelTo="Absolute" Protect="false" Width="4420" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x = { beta + 5} over {2}</SCRIPT></EQUATION><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>4. 따라서 방정식 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000097" Lock="false" NumberingType="Equation" ZOrder="1097"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="5650" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>f(2x - 5) = 0</SCRIPT></EQUATION><CHAR>의 모든 실근의 합은 다음과 같습니다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>   </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000098" Lock="false" NumberingType="Equation" ZOrder="1098"><SIZE Height="2600" HeightRelTo="Absolute" Protect="false" Width="11390" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>alpha + 5} over {2} + { beta + 5} over {2} = { alpha + beta + 10} over {2</SCRIPT></EQUATION><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>5. 문제의 조건에서 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000099" Lock="false" NumberingType="Equation" ZOrder="1099"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="4400" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>alpha + beta = 10</SCRIPT></EQUATION><CHAR>이므로, 이를 대입하면</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>   </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000100" Lock="false" NumberingType="Equation" ZOrder="1100"><SIZE Height="2600" HeightRelTo="Absolute" Protect="false" Width="13770" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>" "실근의" "합" " = {10 + 10} over {2} = {20} over {2} = 10</SCRIPT></EQUATION><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>따라서 구하는 모든 실근의 합은 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000101" Lock="false" NumberingType="Equation" ZOrder="1101"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="1200" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>10</SCRIPT></EQUATION><CHAR>입니다.</CHAR></TEXT></P></PARALIST></ENDNOTE><CHAR> 이차함수 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000102" Lock="false" NumberingType="Equation" ZOrder="1102"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="3450" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>y = f(x)</SCRIPT></EQUATION><CHAR>의 그래프가 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000103" Lock="false" NumberingType="Equation" ZOrder="1103"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="600" WidthRelTo="Absolute"/><POSITION AffectL