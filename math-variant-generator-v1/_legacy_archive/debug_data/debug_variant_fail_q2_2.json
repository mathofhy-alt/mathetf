def solve_v3(k):
    sols = set()
    for n in range(1, 100):
        if -k <= (n-3)**2 <= 6 - k:
            sols.add(n)
    return len(sols)

for k in range(-20, 20):
    if solve_v3(k) == 4:
        print(f"k={k}")

