ION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>D = (-3)^{2} - 4(2 - k) &lt; 0</SCRIPT></EQUATION><CHAR>이어야 하므로 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000018" Lock="false" NumberingType="Equation" ZOrder="1018"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="4400" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>1 + 4k &lt; 0</SCRIPT></EQUATION><CHAR>, 즉 </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000019" Lock="false" NumberingType="Equation" ZOrder="1019"><SIZE Height="2600" HeightRelTo="Absolute" Protect="false" Width="3910" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>k &lt; -{1} over {4}</SCRIPT></EQUATION><CHAR>입니다.</CHAR></TEXT></P></PARALIST></ENDNOTE><CHAR> 직선 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000020" Lock="false" NumberingType="Equation" ZOrder="1020"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="3800" WidthRelTo="Absolute"/><POSITION Af