<P ParaShape="1" Style="0"><TEXT CharShape="0"><ENDNOTE><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="0"><AUTONUM Number="1" NumberType="Endnote"><AUTONUMFORMAT SuffixChar=")" Superscript="false" Type="Digit"/></AUTONUM><CHAR> </CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>[해설] </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000028" Lock="false" NumberingType="Equation" ZOrder="1028"><SIZE Height="3000" HeightRelTo="Absolute" Protect="false" Width="9350" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x^{2}} over {y} - {y^{2}} over {x} = {x^{3} - y^{3}} over {xy</SCRIPT></EQUATION><CHAR>입니다. </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000029" Lock="false" NumberingType="Equation" ZOrder="1029"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="19100" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>(x-y)^{2} = (x+y)^{2} - 4xy = 3 - 4(-3) = 15</SCRIPT></EQUATION><CHAR>에서 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000030" Lock="false" NumberingType="Equation" ZOrder="1030"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="5200" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x-y = sqrt {15}</SCRIPT></EQUATION><CHAR>이고, </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000031" Lock="false" NumberingType="Equation" ZOrder="1031"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="25400" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x^{3}-y^{3} = (x-y)^{3} + 3xy(x-y) = 15 sqrt {15} - 9 sqrt {15} = 6 sqrt {15}</SCRIPT></EQUATION><CHAR>입니다. 따라서 값은 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000032" Lock="false" NumberingType="Equation" ZOrder="1032"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="10200" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>6 sqrt {15} / (-3) = -2 sqrt {15}</SCRIPT></EQUATION><CHAR>입니다.</CHAR></TEXT></P></PARALIST></ENDNOTE><CHAR> , </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000033" Lock="false" NumberingType="Equation" ZOrder="1033"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="3800" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>xy = -3</SCRIPT></EQUATION><CHAR>일 때, </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000034" Lock="false" NumberingType="Equation" ZOrder="1034"><SIZE Height="3000" HeightRelTo="Absolute" Protect="false" Width="4590" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x^{2}} over {y} - {y^{2}} over {x</SCRIPT></EQUATION><CHAR>의 값은? (단, </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000035" Lock="false" NumberingType="Equation" ZOrder="1035"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="2200" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x &gt; y</SCRIPT></EQUATION><CHAR>)</CHAR></TEXT></P>
