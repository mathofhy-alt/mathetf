 Width="4845" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>g(n) = {3n} over {2}</SCRIPT></EQUATION><CHAR>입니다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR>2. (나) 구하기</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="0"><CHAR></CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000267" Lock="false" NumberingType="Equation" ZOrder="1267"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="8850" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>f(x) = -x^{2} + ax + b</SCRIPT></EQUATION><CHAR>의 축의 방정식이 </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000268" Lock="false" NumberingType="Equation" ZOrder="1268"><SIZE Height="2600" HeightRelTo="Absolute" Protect="false" Width="3060" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x = {a} over {2}</SCRIPT></EQUATION><CHAR>이므로, </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version