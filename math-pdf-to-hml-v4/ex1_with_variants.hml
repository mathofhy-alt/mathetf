Offset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>6, 18, 30, 42, 54, 66, 78, 90</SCRIPT></EQUATION><CHAR>이다. 따라서 모든 원소의 합은 </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000035" Lock="false" NumberingType="Equation" ZOrder="1035"><SIZE Height="2600" HeightRelTo="Absolute" Protect="false" Width="7225" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>{8(6+90)} over {2} = 384</SCRIPT></EQUATION><CHAR>이다.</CHAR></TEXT></P></PARALIST></ENDNOTE><CHAR> [1-변형1] 복소수 </CHAR><EQUATION BaseLine="65" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000036" Lock="false" NumberingType="Equation" ZOrder="1036"><SIZE Height="3000" HeightRelTo="Absolute" Protect="false" Width="6035" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>z = { sqrt {3}+i} over {1-i}</SCRIPT></EQUATION><CHAR>에 대하여 집합 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000037" Lock="false" NumberingType="Equation" ZOrder="1037"><SIZE Height="1350" HeightRelTo="Absolute" Protect="false" Width="21300" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAncho