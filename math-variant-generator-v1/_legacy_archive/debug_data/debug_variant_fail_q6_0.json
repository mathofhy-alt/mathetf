def solve_orig():
    ans = 0
    valid_n = []
    for n in range(1, 21):
        for k in range(1, 20):
            if 2**(k+2) < n**2 <= (2**(k+4))/3:
                ans += n
                valid_n.append(n)
                break
    return ans, valid_n

print("Orig ans:", solve_orig())

