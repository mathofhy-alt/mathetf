t="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000301" Lock="false" NumberingType="Equation" ZOrder="1301"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="600" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>x</SCRIPT></EQUATION><CHAR>축과 만난다. </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000302" Lock="false" NumberingType="Equation" ZOrder="1302"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="5300" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>-n le x le 2n</SCRIPT></EQUATION><CHAR>에서 함수 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstId="1000000303" Lock="false" NumberingType="Equation" ZOrder="1303"><SIZE Height="1125" HeightRelTo="Absolute" Protect="false" Width="1850" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="56" Right="56" Top="0"/><SHAPECOMMENT/></SHAPEOBJECT><SCRIPT>f(x)</SCRIPT></EQUATION><CHAR>의 최댓값과 최솟값의 차는 </CHAR><EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60"><SHAPEOBJECT InstI