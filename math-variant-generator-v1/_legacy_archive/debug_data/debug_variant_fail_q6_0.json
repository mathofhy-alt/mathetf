def solve_v1():
    ans = 0
    valid_n = []
    for n in range(1, 21):
        for k in range(1, 20):
            if 4 * 3**k < n**2 <= 4 * 3**(k+2) / 5:
                ans += n
                valid_n.append(n)
                break
    return ans, valid_n

print("V1 ans:", solve_v1())

