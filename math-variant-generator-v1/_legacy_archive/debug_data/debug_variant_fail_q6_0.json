``` python
def solve_v2():
    ans = 0
    for n in range(1, 31):
        # find number of k such that 2^{k+2} < n^2 <= 2^{k+3}
        count = 0
        for k in range(1, 20):
            if 2**(k+2) < n**2 <= 2**(k+3):
                count += 1
        ans += count
    return ans

print("V2 ans:", solve_v2())

```
